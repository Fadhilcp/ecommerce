<%- include("../../views/partials/admin/header") %>

<style>
    :root {
        --primary-color: #bc5501;
        --secondary-color: #a31212;
        --success-color: #10b981;
        --bg-color: #f9fafb;
        --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    }
    
    body {
        background-color: var(--bg-color);
        font-family: system-ui, -apple-system, sans-serif;
    }
    
    .card {
        border: none;
        border-radius: 1rem;
        box-shadow: var(--card-shadow);
        overflow: hidden;
    }
    
    .card-header {
        border-bottom: none;
        padding: 1.5rem;
    }
    
    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        font-weight: 500;
        font-size: 0.875rem;
    }
    
    .order-summary {
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: white;
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 2rem;
    }
    
    .product-image {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 0.5rem;
    }
    
    .table {
        margin-bottom: 0;
    }
    
    .table th {
        border-top: none;
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
    }
    
    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s ease;
    }
    
    .btn-primary {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
    }
    
    .btn-primary:hover {
        background-color: var(--secondary-color);
        border-color: var(--secondary-color);
        transform: translateY(-2px);
    }
    
    .info-label {
        color: #6b7280;
        font-size: 0.875rem;
        margin-bottom: 0.25rem;
    }
    
    .info-value {
        font-weight: 500;
        font-size: 1rem;
        margin-bottom: 1rem;
    }

    .refund-reason-box {
        max-width: 400px;
        border-left: 4px solid #007bff;
        background-color: #f8f9fa;
    }

    .custom-approve-btn {
        background-color: #28a745;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        font-size: 14px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .custom-approve-btn:hover {
        background-color: #218838;
    }

    .custom-reject-btn {
        background-color: #dc3545;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        font-size: 14px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .custom-reject-btn:hover {
        background-color: #c82333;
    }
</style>

<section class="content-main">
    <div class="container py-5">
        
        <div class="order-summary">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h2 class="mb-3">Order #<%= order.orderId %></h2>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="status-badge bg-secondary">Order : <%= order.status %></span>
                        <span class="status-badge bg-success">Payment : <%= order.paymentStatus %></span>
                        <span class="status-badge bg-white text-dark"><%= order.date %></span>
                    </div>
                    <% if (order.coupon && order.coupon.code) { %>
                        <div class="mt-3">
                            <span class="badge bg-dark p-2">Coupon Applied: <%= order.coupon.code %> (<%= order.coupon.discountValue %>%)</span>
                        </div>
                    <% } %>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <div class="row g-2 justify-content-md-end">
                        <div class="col-6 col-md-auto px-3">
                            <small class="text-white-50 d-block">Subtotal</small>
                            <h4 class="mb-0">₹<%= order.totalPrice %></h4>
                        </div>
                        <% if (order.coupon && order.coupon.code) { %>
                            <div class="col-6 col-md-auto px-3 border-start border-white-25">
                                <small class="text-white-50 d-block">Coupon Saved</small>
                                <h4 class="mb-0">-₹<%= ((order.totalPrice * order.coupon.discountValue) / 100).toFixed(2) %></h4>
                            </div>
                        <% } %>
                        <div class="col-6 col-md-auto px-3 border-start border-white-25">
                            <small class="text-white-50 d-block">Shipping</small>
                            <h4 class="mb-0">₹<%= order.shippingFee || 0 %></h4>
                        </div>
                        <div class="col-6 col-md-auto px-3 border-start border-white-25">
                            <small class="text-white-50 d-block fw-bold text-warning">Final Amount</small>
                            <h2 class="mb-0 text-white fw-bold">₹<%= order.finalPrice %></h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Customer Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="info-label">Name</div>
                        <div class="info-value"><%= order.address.name %></div>

                        <div class="info-label">Email</div>
                        <div class="info-value"><%= user.email %></div>
                        
                        <div class="info-label">Phone</div>
                        <div class="info-value"><%= order.address.phone %></div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Shipping Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="info-label">Address</div>
                        <div class="info-value">
                            <%= order.address.houseNo %><br>
                            <%= order.address.street %><br>
                            <%= order.address.city %><br>
                            <%= order.address.state %><br>
                            <%= order.address.pincode %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Order Items</h5>
                    </div>
                    <div class="card-body p-0">
                       <div class="table-responsive">
                            <table class="table table-hover align-middle text-center">
                                <thead>
                                    <tr>
                                        <th class="ps-4 text-start">Product</th>
                                        <th>Quantity</th>
                                        <th>Unit Price</th>
                                        <th class="text-end pe-4">Total Paid Price</th>
                                        <th class="text-center">Status / Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% order.products.forEach((product) => { %>
                                        <tr>
                                            <td class="ps-4 text-start">
                                                <div class="d-flex align-items-center">
                                                    <img src="/uploads/reImage/<%= product.productImage %>" alt="Product" class="product-image me-3">
                                                    <div>
                                                        <h6 class="mb-0 fw-bold"><%= product.productName %></h6>
                                                        <small class="text-muted">Size/Capacity: <%= product.capacity %></small>
                                                    </div>
                                                </div>
                                            </td>
                                            
                                            <td><span class="fw-semibold"><%= product.quantity %></span></td>
                                            <td>₹<%= product.price %></td>
                                            
                                            <td class="text-end pe-4 fw-bold">
                                                <% let originalTotal = product.price * product.quantity; %>
                                                <% if (discountPercentage > 0) { %>
                                                    <% 
                                                        let itemDiscount = (originalTotal * discountPercentage) / 100; 
                                                        let finalItemPrice = originalTotal - itemDiscount;
                                                    %>
                                                    <small class="text-muted text-decoration-line-through d-block mb-1" style="font-size: 0.8rem;">
                                                        ₹<%= originalTotal.toFixed(2) %>
                                                    </small>
                                                    <span class="text-success d-block">₹<%= finalItemPrice.toFixed(2) %></span>
                                                <% } else { %>
                                                    <span>₹<%= originalTotal.toFixed(2) %></span>
                                                <% } %>
                                            </td>
                                            
                                            <td class="text-center">
                                                <div class="d-flex flex-column align-items-center justify-content-center gap-2">
                                                    <% if(product.cancelStatus && product.cancelStatus !== 'Pending') { %>
                                                        <div>
                                                            <span class="badge rounded-pill <%= product.cancelStatus === 'Cancelled' || product.cancelStatus === 'Rejected' ? 'bg-danger' : (product.cancelStatus === 'Approved' || product.cancelStatus === 'Returned' ? 'bg-success' : 'bg-warning text-dark') %>">
                                                                Item: <%= product.cancelStatus %>
                                                            </span>
                                                        </div>
                                                    <% } %>

                                                    <% if (product.cancelStatus === 'Requested' || product.cancelStatus === 'Return Requested' || product.refundStatus === 'Requested') { %>
                                                        <% if (product.cancelStatus !== 'Approved' && product.cancelStatus !== 'Rejected' && product.cancelStatus !== 'Returned') { %>
                                                            <div class="d-flex gap-2 justify-content-center">
                                                                <button class="custom-approve-btn btn-sm" onclick="itemReturnStatus('Approved','<%= product.product %>','<%= order._id %>')">Approve</button>
                                                                <button class="custom-reject-btn btn-sm" onclick="itemReturnStatus('Rejected','<%= product.product %>','<%= order._id %>')">Reject</button>
                                                            </div>
                                                        <% } %>
                                                    <% } %>
                                                    
                                                    <% if((product.cancelStatus === 'Requested' || product.cancelStatus === 'Return Requested' || product.cancelStatus === 'Rejected' || product.cancelStatus === 'Approved' || product.cancelStatus === 'Returned') && (product.refundReason || product.itemCancelReason)) { %>
                                                        <div class="refund-reason-box p-2 border rounded bg-light text-start mx-auto" style="font-size: 0.85rem; max-width: 250px;">
                                                            <strong>Reason:</strong> <%= product.refundReason || product.itemCancelReason %>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <% if(order.paymentStatus !== 'Failed') { %>
                <% if(order.status === 'Pending' || order.status === 'Shipped') {%>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#updateStatusModal">
                        Update Order Status
                    </button>
                <% } %>
            <% } %>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap">
            <% if(order.status === 'Requested' || order.status === 'Return Requested' || order.refundStatus === 'Requested') {%>
                <% if (order.status !== 'Returned' && order.status !== 'Rejected' && order.refundStatus !== 'Approved' && order.refundStatus !== 'Rejected') { %>
                    <div class="refund-reason-box p-3 border rounded bg-light">
                        <strong>Global Return Request Reason:</strong>
                        <p class="mb-0"><%= order.refundReason || 'User requested to return the order.' %></p>
                    </div>

                    <div class="d-flex gap-3">
                        <button class="btn btn-success px-4" onclick="returnStatus('Approved','<%= order._id %>')">Approve Return</button>
                        <button class="btn btn-danger px-4" onclick="returnStatus('Rejected','<%= order._id %>')">Reject Return</button>
                    </div>
                <% } %>
            <% } %>
        </div>
    </div>

    <div class="modal fade" id="updateStatusModal" tabindex="-1" aria-labelledby="updateStatusLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="updateStatusLabel">Update Order Status</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label for="orderStatus" class="form-label">Select Status:</label>
                    <select id="orderStatus" class="form-select bg-secondary text-white border-0">
                        <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                        <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                        <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="saveStatusBtn" onclick="updateStatus('<%= order._id %>')">Update</button>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    async function updateStatus(orderId) {
        const updateStatus = document.getElementById('orderStatus').value;
        try {
            const response = await fetch(`/admin/updateOrderStatus/${orderId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ updateStatus })
            });
            const data = await response.json();
            if(response.ok && data.status){
                await Swal.fire({ icon:'success', title:'Status updated', text:'Status updated' });
                window.location.reload();
            }else{
                Swal.fire({ icon:'warning', title:'Oops', text: data.message });
            }
        } catch (error) { console.error(error); }
    }

    async function returnStatus(result,orderId){
        try {
            const response = await fetch(`/admin/returnStatus/${orderId}`,{
                method:'PATCH',
                headers:{ 'content-type':'application/json' },
                body:JSON.stringify({result})
            });
            const data = await response.json();
            if(data.status){
                await Swal.fire({ icon:'success', title:'Status updated', text:'Status updated' });
                window.location.reload();
            }else{
                Swal.fire({ icon:'error', title:'Error', text:'Something went wrong' });
            }
        } catch (error) { console.error(error); }
    }

    async function itemReturnStatus(result,productId,orderId){
        try {
            const response = await fetch(`/admin/itemReturnStatus/${orderId}`,{
                method:'PATCH',
                headers:{ 'content-type':'application/json' },
                body:JSON.stringify({result,productId})
            });
            const data = await response.json();
            if(data.status){
                await Swal.fire({ icon:'success', title:'Status updated', text:'Status updated' });
                window.location.reload();
            }else{
                Swal.fire({ icon:'error', title:'Error', text: data.message ||'Something went wrong' });
            }
        } catch (error) { console.error(error); }
    }
</script>
<%- include("../../views/partials/admin/footer") %>